<Window x:Class="PcMqttAgent.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки PcMqtt Agent" 
        Height="650" Width="700"
        WindowStartupLocation="CenterScreen"
        MinHeight="400" MinWidth="500">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TabControl Grid.Row="0" Margin="0,0,0,15">
            
            <!-- ВКЛАДКА 1: MQTT -->
            <TabItem Header="MQTT подключение">
                <StackPanel Margin="15">
                    <TextBlock Text="Настройки MQTT брокера" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Сервер:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Mqtt.Server, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Порт:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Mqtt.Port, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Client ID:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Mqtt.ClientId, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Логин:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Mqtt.User, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Пароль:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Mqtt.Password, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Базовый топик (BaseTopic):" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Mqtt.BaseTopic, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                </StackPanel>
            </TabItem>

            <!-- ВКЛАДКА 2: Публикация и Логирование -->
            <TabItem Header="Поведение">
                <StackPanel Margin="15">
                    <TextBlock Text="Публикация данных" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Интервал отправки данных (секунды):" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Publisher.IntervalSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Width="150" HorizontalAlignment="Left" Margin="0,0,0,20"/>
                    
                    <TextBlock Text="Время предупреждения перед выключением (секунды):" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding ShutdownWarningSeconds, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                             Width="150" HorizontalAlignment="Left" Margin="0,0,0,20"/>
                    
                    <Separator Margin="0,10,0,20"/>
                    
                    <TextBlock Text="Логирование" FontWeight="Bold" FontSize="14" Margin="0,0,0,15"/>
                    
                    <TextBlock Text="Путь к файлу лога:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Logging.FilePath, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,10"/>
                    
                    <TextBlock Text="Уровень логирования:" Margin="0,0,0,5"/>
                    <ComboBox SelectedItem="{Binding Logging.LogLevel, Mode=TwoWay}" 
                              Margin="0,0,0,10" Width="200" HorizontalAlignment="Left">
                        <ComboBox.Items>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Verbose</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Debug</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Information</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Warning</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Error</sys:String>
                            <sys:String xmlns:sys="clr-namespace:System;assembly=mscorlib">Fatal</sys:String>
                        </ComboBox.Items>
                    </ComboBox>
                </StackPanel>
            </TabItem>

            <!-- ВКЛАДКА 3: Датчики (DataGrid) -->
            <TabItem Header="Датчики">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Настройка публикуемых датчиков" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                    
                    <!-- Панель поиска -->
                    <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBlock Text="Поиск по имени:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBox x:Name="SearchBox" Width="250" TextChanged="SearchBox_TextChanged"/>
                        <TextBlock x:Name="CountText" VerticalAlignment="Center" Margin="15,0,0,0" Foreground="Gray"/>
                    </StackPanel>

                    <!-- Таблица датчиков -->
                    <DataGrid Grid.Row="2" 
                              x:Name="SensorsGrid"
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False" 
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              SelectionMode="Single"
                              GridLinesVisibility="Horizontal"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <!-- Чекбокс Enabled -->
                            <DataGridTemplateColumn Header="Вкл" Width="50">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <CheckBox IsChecked="{Binding Enabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                  HorizontalAlignment="Center"/>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            
                            <!-- Тип железа -->
                            <DataGridTextColumn Header="Тип устройства" Binding="{Binding HardwareType}" Width="120" IsReadOnly="True"/>
                            
                            <!-- Тип сенсора -->
                            <DataGridTextColumn Header="Тип данных" Binding="{Binding SensorType}" Width="120" IsReadOnly="True"/>
                            
                            <!-- Имя датчика -->
                            <DataGridTextColumn Header="Название (из LibreHardwareMonitor)" Binding="{Binding SensorName}" Width="*" IsReadOnly="True"/>
                            
                            <!-- TopicSuffix - редактируемый -->
                            <DataGridTextColumn Header="Суффикс топика MQTT" Binding="{Binding TopicSuffix, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" Width="180"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

        </TabControl>

        <!-- Кнопки -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="100" Height="35" Margin="0,0,10,0" Click="Save_Click" IsDefault="True"/>
            <Button Content="Отмена" Width="100" Height="35" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>