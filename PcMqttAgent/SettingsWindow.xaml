<Window x:Class="PcMqttAgent.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки PcMqtt Agent" 
        Height="300" Width="400"
        WindowStartupLocation="CenterScreen">
    <StackPanel Margin="20">
        <TextBlock Text="Настройки MQTT" FontWeight="Bold" Margin="0,0,0,10"/>
        
        <TextBlock Text="Сервер:" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Mqtt.Server, Mode=TwoWay}" Margin="0,0,0,10"/>
        
        <TextBlock Text="Интервал отправки (сек):" Margin="0,0,0,5"/>
        <TextBox Text="{Binding Publisher.IntervalSeconds, Mode=TwoWay}" Margin="0,0,0,20"/>

        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Сохранить" Width="80" Margin="0,0,10,0" Click="Save_Click"/>
            <Button Content="Отмена" Width="80" Click="Cancel_Click"/>
        </StackPanel>
    </StackPanel>
</Window>