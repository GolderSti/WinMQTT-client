<Window x:Class="PcMqttAgent.SettingsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Настройки PcMqtt Agent" 
        Height="550" Width="700"
        WindowStartupLocation="CenterScreen"
        ResizeMode="CanResizeWithGrip"
        MinHeight="400" MinWidth="500">
    
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Таблица с вкладками для разных разделов настроек -->
        <TabControl Grid.Row="0">
            
            <!-- Вкладка 1: MQTT -->
            <TabItem Header="MQTT">
                <Grid Margin="15">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Text="Сервер:" Grid.Row="0" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Text="{Binding Settings.Mqtt.Server, UpdateSourceTrigger=PropertyChanged}" Grid.Row="0" Grid.Column="1" Margin="0,8"/>

                    <TextBlock Text="Порт:" Grid.Row="1" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Text="{Binding Settings.Mqtt.Port, UpdateSourceTrigger=PropertyChanged}" Grid.Row="1" Grid.Column="1" Margin="0,8"/>

                    <TextBlock Text="Client ID:" Grid.Row="2" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Text="{Binding Settings.Mqtt.ClientId, UpdateSourceTrigger=PropertyChanged}" Grid.Row="2" Grid.Column="1" Margin="0,8"/>

                    <TextBlock Text="Пользователь:" Grid.Row="3" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Text="{Binding Settings.Mqtt.User, UpdateSourceTrigger=PropertyChanged}" Grid.Row="3" Grid.Column="1" Margin="0,8"/>

                    <TextBlock Text="Пароль:" Grid.Row="4" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Text="{Binding Settings.Mqtt.Password, UpdateSourceTrigger=PropertyChanged}" Grid.Row="4" Grid.Column="1" Margin="0,8"/>

                    <TextBlock Text="Базовый топик:" Grid.Row="5" Grid.Column="0" VerticalAlignment="Center" Margin="0,8"/>
                    <TextBox Text="{Binding Settings.Mqtt.BaseTopic, UpdateSourceTrigger=PropertyChanged}" Grid.Row="5" Grid.Column="1" Margin="0,8"/>
                </Grid>
            </TabItem>

            <!-- Вкладка 2: Общие (Публикация и Логирование) -->
            <TabItem Header="Общие">
                <StackPanel Margin="15">
                    <TextBlock Text="Интервал отправки данных (сек):" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Settings.Publisher.IntervalSeconds, UpdateSourceTrigger=PropertyChanged}" Width="100" HorizontalAlignment="Left" Margin="0,0,0,25"/>

                    <TextBlock Text="Путь к файлу логов:" Margin="0,0,0,5"/>
                    <TextBox Text="{Binding Settings.Logging.FilePath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,0,15"/>

                    <TextBlock Text="Уровень детализации логов:" Margin="0,0,0,5"/>
                    <ComboBox ItemsSource="{Binding LogLevels}" 
                              SelectedItem="{Binding Settings.Logging.LogLevel}" 
                              Width="150" HorizontalAlignment="Left"/>
                </StackPanel>
            </TabItem>

            <!-- Вкладка 3: Датчики -->
            <TabItem Header="Датчики">
                <Grid Margin="15">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    
                    <TextBlock Text="Включайте нужные датчики и меняйте 'Topic Suffix' для красивых имен топиков в MQTT. Кликайте по заголовкам для сортировки." 
                               TextWrapping="Wrap" Margin="0,0,0,10" Foreground="Gray" FontStyle="Italic"/>

                    <DataGrid Grid.Row="1" 
                              ItemsSource="{Binding Settings.Sensors}" 
                              AutoGenerateColumns="False" 
                              CanUserAddRows="False"
                              CanUserDeleteRows="False"
                              IsReadOnly="False"
                              HeadersVisibility="Column"
                              GridLinesVisibility="Horizontal"
                              AlternatingRowBackground="#F9F9F9">
                        <DataGrid.Columns>
                            <!-- Чекбокс включения -->
                            <DataGridCheckBoxColumn Header="Вкл" Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}" Width="50"/>
                            
                            <!-- Информация о датчике (только для чтения) -->
                            <DataGridTextColumn Header="Имя датчика (железо)" Binding="{Binding SensorName}" IsReadOnly="True" Width="*"/>
                            <DataGridTextColumn Header="Тип железа" Binding="{Binding HardwareType}" IsReadOnly="True" Width="100"/>
                            <DataGridTextColumn Header="Тип сенсора" Binding="{Binding SensorType}" IsReadOnly="True" Width="100"/>
                            
                            <!-- Редактируемый суффикс топика -->
                            <DataGridTextColumn Header="Topic Suffix" Binding="{Binding TopicSuffix, UpdateSourceTrigger=PropertyChanged}" Width="150"/>
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- Кнопки управления -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,15,0,0">
            <Button Content="Сохранить" Width="100" Height="30" Margin="0,0,10,0" Click="Save_Click" IsDefault="True" FontWeight="Bold"/>
            <Button Content="Отмена" Width="100" Height="30" Click="Cancel_Click" IsCancel="True"/>
        </StackPanel>
    </Grid>
</Window>